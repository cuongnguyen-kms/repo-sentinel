# Database
DATABASE_URL=postgresql://reposentinel:secret@localhost:5432/reposentinel

# Redis (use a distinct db index if sharing a Redis instance with another project)
REDIS_URL=redis://localhost:6379/1

# Secrets — generate each with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=<64-char-hex>
SESSION_SECRET=<64-char-hex>
BETTER_AUTH_SECRET=<64-char-hex>

# Auth
BETTER_AUTH_URL=http://localhost:3101
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Admin seed account (created on first startup)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=ChangeMe123!

# Ports
API_PORT=3101
WEB_PORT=5175
WEB_ORIGIN=http://localhost:5175

# Claude Code CLI path (override if not in PATH)
CLAUDE_CODE_PATH=claude
